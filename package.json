{
  "name": "my-portfolio-vibha",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "start": "vite --port 4000",
    "start:coverage": "cross-env CYPRESS_COVERAGE=true vite --port 4000",
    "build": "tsc -b && vite build",
    "preview": "vite preview --port 4000",
    "cy:open": "cypress open",
    "cy:run": "start-server-and-test start:coverage http://localhost:4000 \"cypress run\"",
    "test": "npm run cy:run"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "styled-components": "^6.1.18"
  },
  "devDependencies": {
    "@cypress/code-coverage": "^3.14.7",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "cross-env": "^10.1.0",
    "cypress": "^13.17.0",
    "nyc": "^15.1.0",
    "start-server-and-test": "^2.0.10",
    "typescript": "~5.6.3",
    "vite": "^5.4.11",
    "vite-plugin-istanbul": "^6.0.2"
  }
}
